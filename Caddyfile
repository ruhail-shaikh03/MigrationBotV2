migrationbot.duckdns.org {
    route {
        # 1. FastAPI profile check endpoints (explicit backend routes)
        reverse_proxy /api/auth/me backend:8000
        reverse_proxy /api/me backend:8000

        # 2. NextAuth endpoints
        reverse_proxy /api/auth/* frontend:3000
        
        # 3. Backend REST API
        reverse_proxy /api/* backend:8000
        
        # 4. WebSockets
        reverse_proxy /ws* backend:8000
        
        # 5. Frontend Web App (Catch-All)
        reverse_proxy * frontend:3000
    }
}
