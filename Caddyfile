migrationbot.duckdns.org {
    # Frontend (Next.js)
    handle /* {
        reverse_proxy frontend:3000
    }

    # NextAuth endpoints (MUST go to frontend)
    handle /api/auth/* {
        reverse_proxy frontend:3000
    }

    # Backend API (REST)
    handle /api/* {
        reverse_proxy backend:8000
    }

    # WebSocket endpoint (chat)
    handle /ws* {
        reverse_proxy backend:8000
    }
}
