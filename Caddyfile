migrationbot.duckdns.org {
    route {
        # 1. NextAuth endpoints (Highest Priority)
        reverse_proxy /api/auth/* frontend:3000
        
        # 2. Backend REST API
        reverse_proxy /api/* backend:8000
        
        # 3. WebSockets
        reverse_proxy /ws* backend:8000
        
        # 4. Frontend Web App (Catch-All)
        reverse_proxy * frontend:3000
    }
}
